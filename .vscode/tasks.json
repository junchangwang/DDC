{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-debug",
            "type": "shell",
            "command": "cd ${workspaceFolder}/debug && cmake .. -DCMAKE_BUILD_TYPE=Debug -DCMAKE_CXX_FLAGS=\"-O0 -ggdb\" -DCMAKE_C_FLAGS=\"-O0 -ggdb\" && make benchmark_app -j$(nproc)",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
