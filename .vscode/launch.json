{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Compressed Benchmark (WAH)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/debug/benchmark_app",
            "args": ["--compressed-dir", "bm_100m_c100_wah"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build-debug"
        },
